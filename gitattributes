# Normalizar saltos de línea a LF en el repositorio
* text=auto eol=lf

# PHP, CSS, JS, HTML — siempre LF
*.php text eol=lf
*.css text eol=lf
*.js  text eol=lf
*.html text eol=lf
*.htm  text eol=lf
*.json text eol=lf
*.sql  text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.env  text eol=lf

# Binarios — sin conversión
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
